{
  "expo": {
    "name": "Date Navi",
    "slug": "datemate-app",
    "scheme": "datenavi",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/logo.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/logo.png",
      "resizeMode": "contain",
      "backgroundColor": "#FFF8F3"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.datenavi.app",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-localization",
      [
        "expo-image-picker",
        {
          "photosPermission": "프로필 사진을 등록하려면 사진 접근 권한이 필요해요."
        }
      ],
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "내 위치 기반으로 주변 데이트 장소를 추천하려면 위치 권한이 필요해요."
        }
      ],
      [
        "@react-native-google-signin/google-signin",
        {
          "iosUrlScheme": "com.googleusercontent.apps.985430467866-mq27avbj6pjh3kh291vo76plq3apgq5q"
        }
      ],
      [
        "@react-native-seoul/kakao-login",
        {
          "kakaoAppKey": "6ff77dd4e4daa792699cfebdc3cdd9b1"
        }
      ],
      [
        "expo-build-properties",
        {
          "ios": {
            "useFrameworks": "static"
          }
        }
      ]
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "0d5144f6-ce85-47d3-87c9-b29c54ae1d56"
      }
    },
    "owner": "jjjeong"
  }
}
