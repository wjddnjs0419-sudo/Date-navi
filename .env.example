# datemate-app 환경변수 템플릿
# 이 파일을 복사해서 .env (원격) 또는 .env.local (로컬 스택)을 만든다.
#   cp .env.example .env
# 🔴 실제 키 값은 ONBOARDING/관리자에게 받아서 채운다. .env / .env.local 은 git에 올리지 않는다.

# Supabase 프로젝트 URL — 루트 URL만. /rest/v1, /auth/v1 붙이지 말 것.
#   원격:        https://<project-ref>.supabase.co
#   로컬(실기기): http://<맥-LAN-IP>:55321   (ipconfig getifaddr en0 로 IP 확인)
#   로컬(iOS시뮬): http://127.0.0.1:55321
EXPO_PUBLIC_SUPABASE_URL=

# Supabase anon / publishable 키
#   원격: 프로젝트의 anon key (JWT)
#   로컬: supabase status 의 Publishable 키 (sb_publishable_...)
EXPO_PUBLIC_SUPABASE_ANON_KEY=

# Anthropic 키는 클라이언트가 아니라 Supabase Edge Function(generate-ai) 시크릿으로 설정.
#   supabase secrets set ANTHROPIC_API_KEY=sk-ant-... (또는 대시보드 Edge Functions → Secrets)

# 구글 로그인(네이티브) — Google Cloud Console → 사용자 인증 정보에서 발급.
#   iOS/Web 클라이언트 ID는 비밀값 아님(클라이언트 번들에 노출돼도 무방).
#   Client Secret은 여기 넣지 않는다 — Supabase 대시보드(Authentication → Providers → Google)에만 등록.
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=

# 카카오 로컬(장소/맛집 검색) 키 — 위치 기반 실제 장소 추천(place-search)에서 사용.
#   ⚠️ 반드시 "REST API 키" 를 쓴다.
#       - REST API 키   ✅ 서버(Edge Function)에서 로컬 검색 API 호출용 → 이걸 사용
#       - JavaScript 키 ❌ 웹 지도 SDK용(도메인 등록 필요), 검색 API 인증 불가
#       - 네이티브 앱 키 ❌ iOS/Android 지도 SDK용, 검색 API 인증 불가
#   형식: 32자리 영숫자 문자열 (예: 0a1b2c3d4e5f6a7b8c9d0e1f2a3b4c5d)
#   발급: developers.kakao.com → 내 애플리케이션 → 앱 키 → REST API 키
#   ⚠️ Anthropic 키처럼 클라이언트(.env)에 넣지 말고 Edge Function 시크릿으로만 설정(번들 노출 금지):
#       supabase secrets set KAKAO_REST_API_KEY=발급받은REST키 (또는 대시보드 Edge Functions → Secrets)
