# datemate-app 환경변수 템플릿
# 이 파일을 복사해서 .env (원격) 또는 .env.local (로컬 스택)을 만든다.
#   cp .env.example .env
# 🔴 실제 키 값은 ONBOARDING/관리자에게 받아서 채운다. .env / .env.local 은 git에 올리지 않는다.

# Supabase 프로젝트 URL — 루트 URL만. /rest/v1, /auth/v1 붙이지 말 것.
#   원격:        https://<project-ref>.supabase.co
#   로컬(실기기): http://<맥-LAN-IP>:55321   (ipconfig getifaddr en0 로 IP 확인)
#   로컬(iOS시뮬): http://127.0.0.1:55321
EXPO_PUBLIC_SUPABASE_URL=

# Supabase anon / publishable 키
#   원격: 프로젝트의 anon key (JWT)
#   로컬: supabase status 의 Publishable 키 (sb_publishable_...)
EXPO_PUBLIC_SUPABASE_ANON_KEY=

# Google AI Studio (Gemini) API 키 — AI 데이트 카드/문장 생성용
EXPO_PUBLIC_GOOGLE_AI_STUDIO_API_KEY=
